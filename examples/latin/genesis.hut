et cunctus[case=dat, number=pl, gender=masc] animans[case=dat, number=pl] terra[case=gen, number=sg] omnis[case=abl, number=sg, gender=fem]~que volucris[case=dat, number=sg] caelum[case=gen, number=sg] et universus[case=dat, number=pl, gender=masc] qui[case=nom, number=pl, gender=neut] movere[tense=present, person=3, number=pl, voice=passive] in terra "," et in qui[case=abl, number=pl, gender=neut] esse[tense=present, person=3, number=sg, mood=ind] anima vivens "," ut habere[tense=present, person=3, number=pl, mood=subj] ad vescendum "." "»" et factus[case=nom, number=sg, gender=neut] esse[tense=present, person=3, number=sg, mood=ind] ita "."

