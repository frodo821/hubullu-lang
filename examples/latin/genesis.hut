#    et universa ligna quae habent in semetipsis sementem generis sui,
#    ut sint vobis in escam,
dicere[tense=perfect, person=3, number=sg]~que Deus ":" "«" ecce dare[tense=perfect, person=1, number=sg] tu[case=dat, number=pl] omnis[case=acc, number=sg, gender=fem] herba[case=acc, number=sg] adferens[case=acc, number=sg, gender=fem] semen[case=acc, number=sg] super terra[case=acc, number=sg] "," et universus[case=acc, number=pl, gender=neut] lignum[case=acc, number=pl] qui[case=nom, number=pl, gender=neut] habere[tense=present, person=3, number=pl, mood=ind] in semetipse[case=abl, number=pl] sementis[case=acc, number=sg] genus[case=gen, number=sg] suus[case=gen, number=sg, gender=masc] "," ut esse[tense=present, person=3, number=pl, mood=subj] tu[case=dat, number=pl] in esca[case=acc, number=sg] ","

