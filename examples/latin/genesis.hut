benedicere[tense=perfect, person=3, number=sg]~que is[case=dat, number=pl, gender=masc] dicens ":" "«" crescere[tense=present, person=2, number=pl, mood=imp] et multiplicare[tense=present, person=2, number=pl, voice=passive, mood=imp] et replere[tense=present, person=2, number=pl, mood=imp] aqua[case=acc, number=pl] mare[case=gen, number=sg] ";" et avis[case=nom, number=pl] multiplicare[tense=present, person=3, number=pl, voice=passive, mood=subj] super terra[case=acc, number=sg] "." "»"

# 23 Et factum est vespere et mane, dies quintus.
et factus[case=nom, number=sg, gender=neut] esse[tense=present, person=3, number=sg, mood=ind] vespere et mane "," dies[case=nom, number=sg] quintus[case=nom, number=sg, gender=masc] "."

# 24 Dixit quoque Deus: «Producat terra animam viventem in genere suo:
#    iumenta et reptilia et bestias terrae secundum species suas.»
#    Factumque est ita.
dicere[tense=perfect, person=3, number=sg] quoque Deus ":" "«" producere[tense=present, person=3, number=sg, mood=subj] terra anima[case=acc, number=sg] vivens[case=acc, number=sg, gender=fem] in genus[case=abl, number=sg] suus[case=abl, number=sg, gender=neut] ":" iumentum[case=acc, number=pl] et reptile[case=acc, number=pl] et bestia[case=acc, number=pl] terra[case=gen, number=sg] secundum species[case=acc, number=pl] suus[case=acc, number=pl, gender=fem] "." "»" factus[case=nom, number=sg, gender=neut]~que esse[tense=present, person=3, number=sg, mood=ind] ita "."

# 25 Et fecit Deus bestias terrae iuxta species suas,
#    et iumenta et omne reptile terrae in genere suo.
#    Et vidit Deus quod esset bonum.
et facere[tense=perfect, person=3, number=sg, mood=ind] Deus bestia[case=acc, number=pl] terra[case=gen, number=sg] iuxta species[case=acc, number=pl] suus[case=acc, number=pl, gender=fem] "," et iumentum[case=acc, number=pl] et omnis[case=acc, number=sg, gender=neut] reptile[case=acc, number=sg] terra[case=gen, number=sg] in genus[case=abl, number=sg] suus[case=abl, number=sg, gender=neut] "." et videre[tense=perfect, person=3, number=sg] Deus qui[case=nom, number=sg, gender=neut] esse[tense=imperfect, person=3, number=sg, mood=subj] bonus[case=nom, number=sg, gender=neut] "."

# 26 Et ait: «Faciamus hominem ad imaginem et similitudinem nostram;
#    et praesit piscibus maris et volatilibus caeli et bestiis
#    universaeque terrae omnique reptili, quod movetur in terra.»
et aiere[tense=present, person=3, number=sg] ":" "«" facere[tense=present, person=1, number=pl, mood=subj] homo[case=acc, number=sg] ad imago[case=acc, number=sg] et similitudo[case=acc, number=sg] noster[case=acc, number=sg, gender=fem] ";" et praesse[tense=present, person=3, number=sg, mood=subj] piscis[case=dat, number=pl] mare[case=gen, number=sg] et volatile[case=dat, number=pl] caelum[case=gen, number=sg] et bestia[case=dat, number=pl] universus[case=gen, number=sg, gender=fem]~que terra[case=gen, number=sg] omnis[case=abl, number=sg, gender=neut]~que reptile[case=dat, number=sg] "," qui[case=nom, number=sg, gender=neut] movere[tense=present, person=3, number=sg, voice=passive] in terra "." "»"

# 27 Et creavit Deus hominem ad imaginem suam;
