et creare[tense=perfect, person=3, number=sg] Deus homo[case=acc, number=sg] ad imago[case=acc, number=sg] suus[case=acc, number=sg, gender=fem] ";" ad imago[case=acc, number=sg] Deus[case=gen, number=sg] creare[tense=perfect, person=3, number=sg] ille[case=acc, number=sg, gender=masc] "," masculus[case=acc, number=sg] et femina[case=acc, number=sg] creare[tense=perfect, person=3, number=sg] is[case=acc, number=pl, gender=masc] "."

# 28 Benedixitque illis et ait Deus: «Crescite et multiplicamini
#    et replete terram, et subicite eam;
#    et dominamini piscibus maris et volatilibus caeli
#    et universis animantibus quae moventur super terram.»
benedicere[tense=perfect, person=3, number=sg]~que ille[case=dat, number=pl, gender=masc] et aiere[tense=present, person=3, number=sg] Deus ":" "«" crescere[tense=present, person=2, number=pl, mood=imp] et multiplicare[tense=present, person=2, number=pl, voice=passive, mood=imp] et replere[tense=present, person=2, number=pl, mood=imp] terra[case=acc, number=sg] "," et subicere[tense=present, person=2, number=pl, mood=imp] is[case=acc, number=sg, gender=fem] ";" et dominari[tense=present, person=2, number=pl, voice=passive, mood=imp] piscis[case=dat, number=pl] mare[case=gen, number=sg] et volatile[case=dat, number=pl] caelum[case=gen, number=sg] et universus[case=dat, number=pl, gender=masc] animans[case=dat, number=pl] qui[case=nom, number=pl, gender=fem] movere[tense=present, person=3, number=pl, voice=passive] super terra[case=acc, number=sg] "." "»"

