videre[tense=perfect, person=3, number=sg]~que Deus cunctus[case=acc, number=pl, gender=neut] qui[case=nom, number=pl, gender=neut] facere[tense=pluperfect, person=3, number=sg, mood=ind] "," et esse[tense=imperfect, person=3, number=pl, mood=ind] valde bonus[case=nom, number=pl, gender=neut] "." et factus[case=nom, number=sg, gender=neut] esse[tense=present, person=3, number=sg, mood=ind] vespere et mane "," dies[case=nom, number=sg] sextus[case=nom, number=sg, gender=masc] "."
