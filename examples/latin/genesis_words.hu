    [case=nom, number=sg, gender=neut] -> `omne`
    [case=acc, number=sg, gender=neut] -> `omne`
    [case=dat, number=sg, gender=masc] -> `omni`
    [case=dat, number=sg, gender=fem]  -> `omni`
    [case=dat, number=sg, gender=neut] -> `omni`
    [case=abl, number=sg, gender=masc] -> `omni`
    [case=abl, number=sg, gender=fem]  -> `omni`
    [case=abl, number=sg, gender=neut] -> `omni`
    [case=dat, number=pl, gender=masc] -> `omnibus`
    [case=dat, number=pl, gender=fem]  -> `omnibus`
    [case=dat, number=pl, gender=neut] -> `omnibus`
    [case=abl, number=pl, gender=masc] -> `omnibus`
    [case=abl, number=pl, gender=fem]  -> `omnibus`
    [case=abl, number=pl, gender=neut] -> `omnibus`
    [_] -> null
  }
}

