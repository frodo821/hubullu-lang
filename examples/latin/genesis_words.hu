@use * from "profile.hu"

# =========================================================================
# Profile extensions for Genesis vocabulary
# =========================================================================

tagaxis mood {
  role: inflectional
  display: { en: "Mood" }
}

@extend mood_values for tagaxis mood {
  ind  { display: { en: "Indicative" } }
  subj { display: { en: "Subjunctive" } }
  imp  { display: { en: "Imperative" } }
}

@extend tense_ext for tagaxis tense {
  perfect    { display: { en: "Perfect" } }
  pluperfect { display: { en: "Pluperfect" } }
}

@extend pos_ext for tagaxis pos {
  prep   { display: { en: "Preposition" } }
  conj   { display: { en: "Conjunction" } }
  adv    { display: { en: "Adverb" } }
  pron   { display: { en: "Pronoun" } }
  interj { display: { en: "Interjection" } }
}

# =========================================================================
# Indeclinable words
# =========================================================================

entry in    { headword: "in"    tags: [pos=prep]   meaning: "in, into, on" }
entry et    { headword: "et"    tags: [pos=conj]   meaning: "and" }
entry que   { headword: "que"   tags: [pos=conj]   meaning: "and (enclitic)" }
entry autem { headword: "autem" tags: [pos=conj]   meaning: "however, moreover" }
entry super { headword: "super" tags: [pos=prep]   meaning: "above, over" }
entry a     { headword: "a"     tags: [pos=prep]   meaning: "from, by (before consonants)" }
entry ab    { headword: "ab"    tags: [pos=prep]   meaning: "from, by (before vowels)" }
entry ita   { headword: "ita"   tags: [pos=adv]    meaning: "so, thus" }
entry quoque { headword: "quoque" tags: [pos=adv]  meaning: "also, too" }
entry vero  { headword: "vero"  tags: [pos=adv]    meaning: "truly, indeed" }
entry sub   { headword: "sub"   tags: [pos=prep]   meaning: "under, beneath" }
entry iuxta { headword: "iuxta" tags: [pos=prep]   meaning: "next to, according to" }
entry ut    { headword: "ut"    tags: [pos=conj]   meaning: "so that, in order that" }
entry ac    { headword: "ac"    tags: [pos=conj]   meaning: "and (before consonants)" }
entry atque { headword: "atque" tags: [pos=conj]   meaning: "and, as well as" }
entry etiam { headword: "etiam" tags: [pos=adv]    meaning: "also, even" }
entry ad    { headword: "ad"    tags: [pos=prep]   meaning: "to, toward" }
entry ecce  { headword: "ecce"  tags: [pos=interj] meaning: "behold" }
entry valde { headword: "valde" tags: [pos=adv]    meaning: "very, exceedingly" }
entry mane    { headword: "mane"    tags: [pos=adv] meaning: "morning" }
entry vespere { headword: "vespere" tags: [pos=adv] meaning: "evening" }
entry secundum { headword: "secundum" tags: [pos=prep] meaning: "according to" }

# Indeclinable special forms
entry duo          { headword: "duo"          tags: [pos=adj]  meaning: "two" }
entry maius        { headword: "maius"        tags: [pos=adj]  meaning: "greater (comparative)" }
entry minus        { headword: "minus"        tags: [pos=adj]  meaning: "lesser (comparative)" }
entry cete         { headword: "cete"         tags: [pos=noun] meaning: "sea monsters" }
entry vescendum    { headword: "vescendum"    tags: [pos=noun] meaning: "eating (gerund)" }
entry unumquodque  { headword: "unumquodque"  tags: [pos=pron] meaning: "each one" }

